# ---- Server ----
PORT=3001

# ---- Supabase ----
# Find these in your Supabase project:
#   Project Settings -> Data API  (URL)
#   Project Settings -> API Keys  (anon + service_role keys)
# See DATABASE_SETUP.txt for full instructions.

SUPABASE_URL=
SUPABASE_ANON_KEY=

# SECRET — bypasses Row Level Security. Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
