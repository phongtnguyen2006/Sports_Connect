# ---- Server ----
PORT=3001

# ---- Supabase ----
# Find these in your Supabase project:
#   Project Settings -> Data API   (Project URL)
#   Project Settings -> API Keys   (publishable + secret keys)
# See DATABASE_SETUP.txt for full instructions.

SUPABASE_URL=

# Publishable key (sb_publishable_...). Safe to expose. Optional for the backend.
SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...). Bypasses Row Level Security. Server-side only — never expose to the browser.
SUPABASE_SECRET_KEY=
